# LLM Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Database
DATABASE_URL=postgresql://uda_user:uda_password@postgres:5432/uda_rag

# API
API_HOST=0.0.0.0
API_PORT=8000

# Embeddings
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# Ingestão
SCAN_CRON_HOUR=6
SCAN_CRON_MINUTE=0
PDF_STORAGE_PATH=data/pdfs

# Webhook
WEBHOOK_SECRET=your-webhook-secret-key

# Logging
LOG_LEVEL=INFO
